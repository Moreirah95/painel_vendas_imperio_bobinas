 {"cliente": "CONDUFERES IND E COMERCIO DE CONDUTORES ELETRICOS LTDA", "valor": 11510.0, "qtd": 70, "n_notas": 1}, {"cliente": "AEA DISTRIBUIDORA DE MATERIAIS ELETRICOS LTDA", "valor": 10758.0, "qtd": 99, "n_notas": 1}, {"cliente": "CABEL IND COM DE CONDUTORES ELETRICOS LTDA", "valor": 8670.0, "qtd": 30, "n_notas": 1}, {"cliente": "CONDUMIG INDUSTRIA DE CONDUTORES ELETRICOS MINAS GERAIS SA", "valor": 6443.8, "qtd": 19, "n_notas": 1}, {"cliente": "VIMACOM INDUSTRIA E COMERCIO LTDA", "valor": 4440.0, "qtd": 12, "n_notas": 1}, {"cliente": "ENGEPER ENGENHARIA E PERFURACOES LTDA", "valor": 2320.0, "qtd": 10, "n_notas": 2}, {"cliente": "MMEDIATE COMERCIO DE FIOS E CABOS ESPECIAIS LTDA", "valor": 1323.0, "qtd": 10, "n_notas": 1}, {"cliente": "EMPRESA BRASILEIRA DE LOCACAO DE EQUIPAMENTOS LTDA", "valor": 993.0, "qtd": 10, "n_notas": 1}], "total_valor": 7450683.55, "total_qtd": 62239, "total_clientes": 30, "total_notas": 486}
;

const fmtMoney = v => 'R$ ' + Math.round(v).toLocaleString('pt-BR', {minimumFractionDigits:0, maximumFractionDigits:0});
const fmtInt = v => Math.round(v).toLocaleString('pt-BR');

let state = { cliente: '', tamanho: '' };

function colorForIndex(i, total){
  const t = i / Math.max(1,total-1);
  const c1 = [217,150,84], c2 = [122,67,34];
  const r = Math.round(c1[0] + (c2[0]-c1[0])*t);
  const g = Math.round(c1[1] + (c2[1]-c1[1])*t);
  const b = Math.round(c1[2] + (c2[2]-c1[2])*t);
  return `rgb(${r},${g},${b})`;
}

function init(){
  const selCliente = document.getElementById('filterCliente');
  DATA.clientes.forEach(c=>{
    const opt = document.createElement('option');
    opt.value = c; opt.textContent = c;
    selCliente.appendChild(opt);
  });

  const selTamanho = document.getElementById('filterTamanho');
  DATA.tamanhos.forEach(t=>{
    const opt = document.createElement('option');
    opt.value = t; opt.textContent = t + ' cm';
    selTamanho.appendChild(opt);
  });

  selCliente.addEventListener('change', e=>{ state.cliente = e.target.value; render(); });
  selTamanho.addEventListener('change', e=>{ state.tamanho = e.target.value; render(); });
  document.getElementById('resetBtn').addEventListener('click', ()=>{
    state = {cliente:'', tamanho:''};
    selCliente.value=''; selTamanho.value='';
    render();
  });

  render();
}

// ---- Core data accessors ----

// Returns {qtd, valor} for a given client + size combo (uses precomputed matrix)
function getCell(cliente, tamanho){
  const m = DATA.cliente_tamanho_matrix[cliente];
  if(!m) return {qtd:0, valor:0};
  return m[tamanho] || {qtd:0, valor:0};
}

// Totals for current filter combination (drives header stats)
function getFilteredTotals(){
  if(state.cliente && state.tamanho){
    return getCell(state.cliente, state.tamanho);
  }
  if(state.cliente && !state.tamanho){
    const row = DATA.by_cliente.find(c=>c.cliente===state.cliente);
    return row ? {qtd:row.qtd, valor:row.valor} : {qtd:0,valor:0};
  }
  if(!state.cliente && state.tamanho){
    const row = DATA.by_size.find(s=>s.tamanho===state.tamanho);
    return row ? {qtd:row.qtd, valor:row.valor} : {qtd:0,valor:0};
  }
  return {qtd: DATA.total_qtd, valor: DATA.total_valor};
}

function computeSizeTotals(){
  // qty + valor by size, respecting cliente filter
  if(!state.cliente){
    return DATA.by_size.map(s=>({tamanho:s.tamanho, qtd:s.qtd, valor:s.valor}));
  }
  return DATA.tamanhos
    .map(t=>{ const cell = getCell(state.cliente, t); return {tamanho:t, qtd:cell.qtd, valor:cell.valor}; })
    .filter(s=>s.qtd>0)
    .sort((a,b)=>b.qtd-a.qtd);
}

function computeClientTotals(){
  // list of {cliente, qtd, valor} respecting tamanho filter
  if(!state.tamanho){
    return DATA.by_cliente.map(c=>({cliente:c.cliente, qtd:c.qtd, valor:c.valor}));
  }
  return DATA.clientes
    .map(c=>{ const cell = getCell(c, state.tamanho); return {cliente:c, qtd:cell.qtd, valor:cell.valor}; })
    .filter(r=>r.qtd>0)
    .sort((a,b)=>b.valor-a.valor);
}

// ---- Render ----

function render(){
  renderHeaderStats();
  renderSizeBars();
  renderTable();
  renderClientBars();
  renderActivePill();
}

function renderHeaderStats(){
  const totals = getFilteredTotals();
  const anyFilter = !!(state.cliente || state.tamanho);
  const valorEl = document.getElementById('statValor');
  const qtdEl = document.getElementById('statQtd');
  valorEl.textContent = fmtMoney(totals.valor);
  qtdEl.textContent = fmtInt(totals.qtd);
  valorEl.classList.toggle('is-filtered', anyFilter);
  qtdEl.classList.toggle('is-filtered', anyFilter);

  document.getElementById('statValorLabel').textContent = anyFilter ? 'Faturado (filtro)' : 'Faturado';
  document.getElementById('statQtdLabel').textContent = anyFilter ? 'Bobinas (filtro)' : 'Bobinas';

  // clients count: how many clients are represented in the current filter
  let nClientes;
  if(state.cliente){
    nClientes = 1;
  } else if(state.tamanho){
    nClientes = computeClientTotals().length;
  } else {
    nClientes = DATA.total_clientes;
  }
  document.getElementById('statClientes').textContent = nClientes;
}

function renderActivePill(){
  const pill = document.getElementById('activePill');
  let parts = [];
  if(state.cliente) parts.push(`Cliente: <b>${state.cliente.slice(0,40)}</b>`);
  if(state.tamanho) parts.push(`Tamanho: <b>${state.tamanho} cm</b>`);
  pill.innerHTML = parts.length ? parts.join(' &nbsp;·&nbsp; ') : 'Sem filtros ativos';
}

function renderSizeBars(){
  const data = computeSizeTotals();
  const max = Math.max(...data.map(d=>d.qtd), 1);
  const container = document.getElementById('sizeBars');
  container.innerHTML = '';
  data.forEach(d=>{
    const row = document.createElement('div');
    row.className = 'bar-row';
    const pct = (d.qtd/max*100).toFixed(1);
    row.innerHTML = `
      <div class="lbl">${d.tamanho} cm</div>
      <div class="bar-track"><div class="bar-fill" style="width:${pct}%"></div>
        <div class="bar-val">${fmtInt(d.qtd)} un · ${fmtMoney(d.valor)}</div>
      </div>`;
    container.appendChild(row);
  });
  document.getElementById('sizeSub').textContent = state.cliente
    ? `Unidades vendidas para ${state.cliente.slice(0,50)}, por tamanho`
    : 'Total de unidades vendidas, somando todas as notas fiscais';
  document.getElementById('sizeFoot').textContent =
    state.cliente ? `Mostrando apenas: ${state.cliente}` : `${data.length} tamanhos distintos no total`;
}

function renderTable(){
  const head = document.getElementById('tableHead');
  const body = document.getElementById('tableBody');

  if(state.cliente){
    head.innerHTML = `<th>Tamanho</th><th class="num">Quantidade</th><th class="num">Valor (R$)</th>`;
    const rows = DATA.tamanhos
      .map(t=>{ const cell = getCell(state.cliente, t); return {t, q:cell.qtd, v:cell.valor}; })
      .filter(r=>r.q>0).sort((a,b)=>b.q-a.q);
    body.innerHTML = rows.map(r=>`<tr><td class="size-name">${r.t} cm</td><td class="num">${fmtInt(r.q)}</td><td class="num">${fmtMoney(r.v)}</td></tr>`).join('');
    if(rows.length===0) body.innerHTML = `<tr><td colspan="3" style="color:var(--steel)">Sem compras registradas</td></tr>`;
  } else {
    head.innerHTML = `<th>Cliente</th><th class="num">Tamanhos comprados</th><th class="num">Total unidades</th>`;
    const rows = DATA.clientes.map(c=>{
      let tamanhosComprados = 0, totalUnid = 0;
      DATA.tamanhos.forEach(t=>{
        const cell = getCell(c, t);
        if(state.tamanho && t!==state.tamanho) return;
        if(cell.qtd>0) tamanhosComprados++;
        totalUnid += cell.qtd;
      });
      return {cliente:c, tamanhosComprados, totalUnid};
    }).filter(r=> state.tamanho ? r.totalUnid>0 : true)
      .sort((a,b)=>b.totalUnid-a.totalUnid);
    body.innerHTML = rows.map(r=>`<tr><td>${r.cliente}</td><td class="num">${r.tamanhosComprados}</td><td class="num">${fmtInt(r.totalUnid)}</td></tr>`).join('');
  }
}

function renderClientBars(){
  const data = computeClientTotals();
  const container = document.getElementById('clientBars');
  container.innerHTML = '';
  const max = Math.max(...data.map(d=>d.valor), 1);

  const badge = document.getElementById('clientsBadge');
  const title = document.getElementById('clientsTitle');
  const sub = document.getElementById('clientsSub');
  if(state.tamanho){
    badge.style.display = 'inline-block';
    badge.textContent = `Tamanho ${state.tamanho} cm`;
    title.textContent = `Faturamento por cliente — bobinas ${state.tamanho} cm`;
    sub.textContent = 'Valor vendido apenas deste tamanho, por cliente, do que mais comprou para o que menos comprou';
  } else {
    badge.style.display = 'none';
    title.textContent = 'Faturamento por cliente';
    sub.textContent = 'Ordenado do que mais comprou para o que menos comprou — clique numa barra para detalhar nos painéis acima';
  }

  data.forEach((d,i)=>{
    const row = document.createElement('div');
    row.className = 'client-row' + (state.cliente===d.cliente ? ' selected' : '');
    const pct = (d.valor/max*100).toFixed(1);
    const display = `${fmtMoney(d.valor)} · ${fmtInt(d.qtd)} un`;
    row.innerHTML = `
      <div class="rank">${i+1}</div>
      <div class="lbl" title="${d.cliente}">${d.cliente}</div>
      <div class="client-track"><div class="client-fill" style="width:${pct}%; background:${colorForIndex(i,data.length)}"></div>
        <div class="client-val">${display}</div>
      </div>`;
    row.addEventListener('click', ()=>{
      state.cliente = (state.cliente === d.cliente) ? '' : d.cliente;
      document.getElementById('filterCliente').value = state.cliente;
      render();
    });
    container.appendChild(row);
  });
}

init();
</script>
</body>
</html>
