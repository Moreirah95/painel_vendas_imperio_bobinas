A  /* HEADER */
  header{
    display:flex; justify-content:space-between; align-items:flex-end;
    border-bottom:2px solid var(--wood);
    padding-bottom:18px; margin-bottom:28px;
    flex-wrap:wrap; gap:16px;
  }
  .brand-block{
    display:flex; align-items:center; gap:18px;
  }
  .brand-logo{
    width:72px; height:72px; border-radius:50%; flex-shrink:0;
    border:2px solid var(--wood); box-shadow:0 0 0 4px rgba(181,112,58,0.12);
    background:var(--bg-panel2);
  }
  .brand-eyebrow{
    font-family:'JetBrains Mono','Courier New',monospace; font-size:11px; letter-spacing:.18em;
    color:var(--wood-light); text-transform:uppercase; margin-bottom:6px;
  }
  h1{
    font-family:'Archivo','Segoe UI',Arial,sans-serif; font-weight:800; font-size:34px; letter-spacing:-0.01em;
    color:var(--cream); line-height:1.05;
  }
  h1 span{color:var(--wood-light);}
  .subtitle{font-size:14px; color:var(--cream-dim); margin-top:6px; max-width:560px;}
  .header-stats{display:flex; gap:28px;}
  .hstat{text-align:right;}
  .hstat .n{font-family:'Archivo','Segoe UI',Arial,sans-serif; font-weight:700; font-size:26px; color:var(--wood-light); line-height:1; transition:color .2s;}
  .hstat .n.is-filtered{color:#e8b272;}
  .hstat .l{font-family:'JetBrains Mono','Courier New',monospace; font-size:10px; letter-spacing:.1em; color:var(--steel); text-transform:uppercase; margin-top:4px;}

  /* FILTER BAR */
  .filterbar{
    display:flex; align-items:center; gap:14px; flex-wrap:wrap;
    background:var(--bg-panel); border:1px solid var(--line); border-radius:8px;
    padding:14px 18px; margin-bottom:26px;
  }
  .filterbar .flabel{
    font-family:'JetBrains Mono','Courier New',monospace; font-size:10.5px; letter-spacing:.1em;
    color:var(--steel); text-transform:uppercase; white-space:nowrap;
  }
  select{
    background:var(--bg-panel2); color:var(--cream); border:1px solid var(--line);
    border-radius:5px; padding:8px 12px; font-family:'Archivo Narrow','Segoe UI',Arial,sans-serif; font-size:13.5px;
    min-width:240px; cursor:pointer;
  }
  select:focus{outline:2px solid var(--wood-light); outline-offset:1px;}
  .reset-btn{
    background:transparent; border:1px solid var(--wood-dark); color:var(--wood-light);
    font-family:'JetBrains Mono','Courier New',monospace; font-size:11px; letter-spacing:.06em; text-transform:uppercase;
    padding:8px 14px; border-radius:5px; cursor:pointer; transition:.15s;
  }
  .reset-btn:hover{background:var(--wood-dark); color:var(--cream);}
  .active-pill{
    margin-left:auto; font-family:'JetBrains Mono','Courier New',monospace; font-size:11px; color:var(--cream-dim);
  }
  .active-pill b{color:var(--wood-light);}

  /* PANEL GRID */
  .grid{display:grid; grid-template-columns:1fr 1fr; gap:22px;}
  .panel{
    background:var(--bg-panel); border:1px solid var(--line); border-radius:10px;
    padding:22px 24px 20px; position:relative; overflow:hidden;
  }
  .panel.full{grid-column:1/-1;}
  .panel-head{display:flex; justify-content:space-between; align-items:baseline; margin-bottom:4px;}
  .panel-num{
    font-family:'JetBrains Mono','Courier New',monospace; font-size:11px; color:var(--wood-light);
    letter-spacing:.1em;
  }
  .panel-badge{
    font-family:'JetBrains Mono','Courier New',monospace; font-size:10.5px; color:var(--wood-light);
    background:rgba(181,112,58,0.15); border:1px solid var(--wood-dark); border-radius:4px;
    padding:3px 9px;
  }
  .panel-title{
    font-family:'Archivo','Segoe UI',Arial,sans-serif; font-weight:700; font-size:17px; color:var(--cream);
    margin-top:2px;
  }
  .panel-sub{font-size:12.5px; color:var(--cream-dim); margin-bottom:16px; margin-top:2px;}
  .panel-foot{font-size:11px; color:var(--steel); margin-top:14px; font-family:'JetBrains Mono','Courier New',monospace;}

  /* BAR ROWS (generic horizontal bars) */
  .bar-row{display:flex; align-items:center; gap:10px; margin-bottom:9px;}
  .bar-row .lbl{
    width:120px; flex-shrink:0; font-family:'JetBrains Mono','Courier New',monospace; font-size:12px; color:var(--cream-dim);
    text-align:right; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;
  }
  .bar-track{flex:1; background:var(--bg-panel2); border-radius:4px; height:22px; position:relative; overflow:hidden;}
  .bar-fill{
    height:100%; border-radius:4px; background:linear-gradient(90deg, var(--wood-dark), var(--wood-light));
    display:flex; align-items:center; transition:width .5s cubic-bezier(.2,.8,.2,1);
  }
  .bar-val{
    position:absolute; right:8px; top:0; bottom:0; display:flex; align-items:center;
    font-family:'JetBrains Mono','Courier New',monospace; font-size:11.5px; color:var(--cream); white-space:nowrap;
  }

  /* CLIENT BARS (panel 4) — taller, full width */
  .client-row{display:flex; align-items:center; gap:12px; margin-bottom:7px; cursor:pointer;}
  .client-row .rank{
    width:22px; flex-shrink:0; font-family:'JetBrains Mono','Courier New',monospace; font-size:11px; color:var(--steel); text-align:right;
  }
  .client-row .lbl{
    width:300px; flex-shrink:0; font-size:12.5px; color:var(--cream-dim);
    overflow:hidden; text-overflow:ellipsis; white-space:nowrap;
  }
  .client-row.selected .lbl{color:var(--wood-light); font-weight:600;}
  .client-track{flex:1; background:var(--bg-panel2); border-radius:4px; height:20px; position:relative; overflow:hidden;}
  .client-fill{
    height:100%; border-radius:4px; transition:width .5s cubic-bezier(.2,.8,.2,1);
  }
  .client-val{
    position:absolute; right:8px; top:0; bottom:0; display:flex; align-items:center;
    font-family:'JetBrains Mono','Courier New',monospace; font-size:11px; color:var(--cream); white-space:nowrap;
  }
  .client-row:hover .client-track{outline:1px solid var(--wood-light);}

  /* TABLE (panel 2) */
  table{width:100%; border-collapse:collapse; font-size:12.5px;}
  thead th{
    text-align:left; font-family:'JetBrains Mono','Courier New',monospace; font-size:10.5px; letter-spacing:.07em;
    color:var(--steel); text-transform:uppercase; padding:7px 8px; border-bottom:1px solid var(--line);
    position:sticky; top:0; background:var(--bg-panel);
  }
  thead th.num{text-align:right;}
  tbody td{padding:7px 8px; border-bottom:1px solid var(--line); color:var(--cream-dim);}
  tbody td.num{text-align:right; font-family:'JetBrains Mono','Courier New',monospace; color:var(--cream);}
  tbody tr:hover{background:var(--bg-panel2);}
  tbody td.size-name{color:var(--wood-light); font-weight:600; font-family:'JetBrains Mono','Courier New',monospace;}
  .table-scroll{max-height:330px; overflow-y:auto;}
  .table-scroll::-webkit-scrollbar{width:6px;}
  .table-scroll::-webkit-scrollbar-thumb{background:var(--wood-dark); border-radius:3px;}

  .legend-note{
    font-size:11.5px; color:var(--steel); font-style:italic; margin-top:10px;
  }

  footer{
    text-align:center; font-family:'JetBrains Mono','Courier New',monospace; font-size:10.5px; color:var(--steel);
    margin-top:40px; letter-spacing:.05em;
  }

  @media (max-width:900px){
    .grid{grid-template-columns:1fr;}
    .client-row .lbl{width:160px;}
    .bar-row .lbl{width:80px;}
    .header-stats{gap:16px;}
    .brand-logo{width:52px; height:52px;}
  }
</style>
</head>
<body>
<div class="wrap">

  <header>
    <div class="brand-block">
      <img src="data:image/png;base64," alt="Imperio das Bobinas" class="brand-logo">
      <div>
        <div class="brand-eyebrow">Imperio das Bobinas Ltda · Análise comercial</div>
        <h1>Painel de <span>Vendas</span></h1>
        <div class="subtitle">Consolidado de 487 notas fiscais eletrônicas emitidas — bobinas de madeira por tamanho, cliente e faturamento.</div>
      </div>
    </div>
    <div class="header-stats">
      <div class="hstat"><div class="n" id="statValor">—</div><div class="l" id="statValorLabel">Faturado</div></div>
      <div class="hstat"><div class="n" id="statQtd">—</div><div class="l" id="statQtdLabel">Bobinas</div></div>
      <div class="hstat"><div class="n" id="statClientes">—</div><div class="l">Clientes</div></div>
    </div>
  </header>

  <div class="filterbar">
    <span class="flabel">Filtrar por cliente</span>
    <select id="filterCliente">
      <option value="">Todos os clientes</option>
    </select>
    <span class="flabel">Filtrar por tamanho</span>
    <select id="filterTamanho">
      <option value="">Todos os tamanhos</option>
    </select>
    <button class="reset-btn" id="resetBtn">Limpar filtros</button>
    <span class="active-pill" id="activePill"></span>
  </div>

  <div class="grid">

    <div class="panel" id="panelSizes">
      <div class="panel-head"><span class="panel-num">01</span></div>
      <div class="panel-title">Quantidade vendida por tamanho de bobina</div>
      <div class="panel-sub" id="sizeSub">Total de unidades vendidas, somando todas as notas fiscais</div>
      <div id="sizeBars"></div>
      <div class="panel-foot" id="sizeFoot"></div>
    </div>

    <div class="panel" id="panelTable">
      <div class="panel-head"><span class="panel-num">02</span></div>
      <div class="panel-title">Tamanhos comprados por cliente</div>
      <div class="panel-sub">Selecione um cliente no filtro acima para detalhar — exibindo todos por padrão</div>
      <div class="table-scroll">
        <table>
          <thead><tr id="tableHead"></tr></thead>
          <tbody id="tableBody"></tbody>
        </table>
      </div>
    </div>

    <div class="panel full" id="panelClients">
      <div class="panel-head">
        <span class="panel-num">03 · 04</span>
        <span class="panel-badge" id="clientsBadge" style="display:none;"></span>
      </div>
      <div class="panel-title" id="clientsTitle">Faturamento por cliente</div>
      <div class="panel-sub" id="clientsSub">Ordenado do que mais comprou para o que menos comprou — clique numa barra para detalhar nos painéis acima</div>
      <div id="clientBars"></div>
      <div class="legend-note">Clique numa barra para isolar o cliente nos filtros · clique novamente para limpar</div>
    </div>

  </div>

  <footer>IMPERIO DAS BOBINAS LTDA — CNPJ 55.577.762/0001-47 — DADOS EXTRAÍDOS DE 487 NF-e (MAI/2024 – JUN/2026)</footer>
</div>

